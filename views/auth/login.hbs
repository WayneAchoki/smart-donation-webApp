<div class="d-flex justify-content-center align-items-center vh-100 bg-light">
  <div
    class="card shadow-lg p-4 rounded-4"
    style="max-width: 420px; width: 100%;"
  >
    <div class="card-body">
      <h3 class="text-center mb-4 fw-bold text-primary">USER LOGIN</h3>
      <p class="text-center text-muted mb-4">Login to your Smart Donation
        account</p>

      <form action="/login" method="POST">
        <!-- Email -->
        <div class="mb-3">
          <label for="email" class="form-label">Email address</label>
          <input
            type="email"
            name="email"
            id="email"
            class="form-control rounded-3 border border-secondary"
            placeholder="wayne@achoki.com"
            required
            style="height: 38px; padding: 0.5rem 0.75rem;"
          />
        </div>

        <!-- Password -->
        <div class="mb-3">
          <label for="password" class="form-label">Password</label>
          <input
            type="password"
            name="password"
            id="password"
            class="form-control rounded-3 border border-secondary"
            placeholder="Password"
            required
            style="height: 38px; padding: 0.5rem 0.75rem;"
          />
        </div>

        <!-- Login Button -->
        <button
          class="btn btn-primary w-100 mb-3"
          type="submit"
          style="background: linear-gradient(135deg, #1a3c72, #2a5298); border:none; height: 42px;"
        >
          Login
        </button>

        <p class="text-center text-muted mt-2 mb-0">
          Don't have an account?
          <a
            href="/register"
            class="text-primary fw-bold text-decoration-none"
          >Sign Up</a>
        </p>
      </form>
    </div>
  </div>
</div>