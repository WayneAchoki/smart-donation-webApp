<div class="container-fluid mt-4 px-4">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
          <h4 class="mb-0">Submit {{type}} Request</h4>
        </div>
        <div class="card-body">

          {{#if success_msg}}<div
              class="alert alert-success"
            >{{success_msg}}</div>{{/if}}
          {{#if error_msg}}<div
              class="alert alert-danger"
            >{{error_msg}}</div>{{/if}}

          <form
            action="/company/submit"
            method="POST"
            enctype="multipart/form-data"
          >
            <input type="hidden" name="type" value="{{type}}" />

            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">Company Name *</label>
                <input
                  type="text"
                  name="companyName"
                  class="form-control"
                  required
                />
              </div>
              <div class="col-md-6">
                <label class="form-label">License Number *</label>
                <input
                  type="text"
                  name="licenseNumber"
                  class="form-control"
                  required
                />
              </div>

              <div class="col-md-6">
                <label class="form-label">Location *</label>
                <input
                  type="text"
                  name="location"
                  class="form-control"
                  required
                />
              </div>
              <div class="col-md-6">
                <label class="form-label">Founder’s Name *</label>
                <input
                  type="text"
                  name="founderName"
                  class="form-control"
                  required
                />
              </div>

              {{#if (eq type "donation")}}
                <div class="col-md-6">
                  <label class="form-label">Amount (KES)</label>
                  <input
                    type="number"
                    name="amount"
                    class="form-control"
                    step="0.01"
                  />
                </div>
                <div class="col-md-6">
                  <label class="form-label">Items (comma-separated)</label>
                  <input
                    type="text"
                    name="items"
                    class="form-control"
                    placeholder="Rice, Beans, Oil"
                  />
                </div>
              {{/if}}

              <div class="col-12">
                <label class="form-label">Verification Documents (PDF/JPG/PNG -
                  max 5) *</label>
                <input
                  type="file"
                  name="verificationDocs"
                  class="form-control"
                  multiple
                  accept=".pdf,.jpg,.jpeg,.png"
                  required
                />
              </div>

              <div class="col-12">
                <label class="form-label">Message (Optional)</label>
                <textarea
                  name="message"
                  class="form-control"
                  rows="3"
                ></textarea>
              </div>

              <div class="col-12 text-end mt-4">
                <a
                  href="/company/dashboard"
                  class="btn btn-secondary me-2"
                >Cancel</a>
                <button type="submit" class="btn btn-primary">Submit Request</button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>