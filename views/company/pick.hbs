<div class="container-fluid mt-4 px-4">
  <h3 class="mb-4">All Company Requests</h3>

  {{#if ../success_msg}}
    <div class="alert alert-success">{{../success_msg}}</div>
  {{/if}}
  {{#if ../error_msg}}
    <div class="alert alert-danger">{{../error_msg}}</div>
  {{/if}}

  <!-- SEARCH & FILTERS -->
  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <form method="GET" action="/pick" id="searchForm">
        <div class="row g-3 align-items-end">
          <div class="col-md-4">
            <label class="form-label">Search Companies</label>
            <input type="text" name="search" class="form-control" placeholder="Company name, email, or type..." value="{{searchQuery}}" />
          </div>
          <div class="col-md-3">
            <label class="form-label">Status</label>
            <select name="status" class="form-select">
              <option value="">All Status</option>
              <option value="pending" {{#if (eq statusFilter "pending")}}selected{{/if}}>Pending</option>
              <option value="approved" {{#if (eq statusFilter "approved")}}selected{{/if}}>Approved</option>
              <option value="rejected" {{#if (eq statusFilter "rejected")}}selected{{/if}}>Rejected</option>
            </select>
          </div>
          <div class="col-md-3">
            <label class="form-label">Request Type</label>
            <select name="type" class="form-select">
              <option value="">All Types</option>
              <option value="donation" {{#if (eq typeFilter "donation")}}selected{{/if}}>Donation</option>
              <option value="partnership" {{#if (eq typeFilter "partnership")}}selected{{/if}}>Partnership</option>
              <option value="csr" {{#if (eq typeFilter "csr")}}selected{{/if}}>CSR</option>
            </select>
          </div>
          <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Filter</button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <!-- RESULTS COUNTER -->
  <div class="mb-3">
    <p class="text-muted mb-2">
      Showing <strong>{{filteredCount}}</strong> of <strong>{{totalCount}}</strong> total requests
      {{#if searchQuery}}<span class="badge bg-info ms-2">Searching "{{searchQuery}}"</span>{{/if}}

      <!-- NEW: Badge for Companies only -->
      {{#if (eq ../user.role "company")}}
        <span class="badge bg-secondary ms-2">Your requests only</span>
      {{/if}}
    </p>
  </div>

  <!-- MAIN TABLE -->
  <div class="card shadow-sm">
    <div class="card-header bg-light border-0">
      <div class="d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Requests List</h6>
        <a href="/pick" class="btn btn-sm btn-outline-secondary">Reset Filters</a>
      </div>
    </div>
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-hover align-middle">
          <thead class="table-light">
            <tr>
              <th>#</th>
              <th>Company</th>
              <th>Type</th>
              <th>Details</th>
              <th>Submitted</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            {{#each requests}}
              <tr>
                <td class="fw-medium text-muted">{{add @index 1}}</td>
                <td>
                  <div class="d-flex align-items-center">
                    <div class="avatar avatar-sm me-3 bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center">
                      Building
                    </div>
                    <div>
                      <div class="fw-bold">{{company.name}}</div>
                      <small class="text-muted">{{company.email}}</small>
                    </div>
                  </div>
                </td>
                <td>
                  <span class="badge
                    {{#if (eq type "donation")}}bg-success{{/if}}
                    {{#if (eq type "partnership")}}bg-info{{/if}}
                    {{#if (eq type "csr")}}bg-warning text-dark{{/if}}
                  ">{{type}}</span>
                </td>
                <td>
                  <div class="small">
                    {{#if amount}}
                      KES {{formatNumber amount}}
                    {{else}}
                      {{#if items.length}}
                        {{items.length}} item{{#if (gt items.length 1)}}s{{/if}}
                        <br><small class="text-muted">
                          {{#each items}}
                            {{this}}{{#unless @last}}, {{/unless}}
                          {{/each}}
                        </small>
                      {{else}}
                        Project Details
                      {{/if}}
                    {{/if}}
                  </div>
                  {{#if message}}
                    <div class="mt-1">
                      <small class="text-muted fst-italic">"{{truncate message 50}}"</small>
                    </div>
                  {{/if}}
                </td>
                <td>
                  <div class="small">{{formatDate createdAt}}</div>
                  <div class="text-muted small">{{formatRelative createdAt}}</div>
                </td>

                <!-- STATUS COLUMN: NGO GETS DROPDOWN ON EVERY ROW -->
                <td>
                  {{#if (eq ../user.role "ngo")}}
                    <form action="/ngo/company/request/update/{{_id}}" method="POST" class="d-inline">
                      <select name="status"
                              class="form-select form-select-sm w-auto d-inline-block"
                              onchange="this.form.submit()">
                        <option value="pending"   {{#if (eq status "pending")}}selected{{/if}}>Pending</option>
                        <option value="approved"  {{#if (eq status "approved")}}selected{{/if}}>Approved</option>
                        <option value="rejected"  {{#if (eq status "rejected")}}selected{{/if}}>Rejected</option>
                      </select>
                      <input type="hidden" name="returnUrl" value="{{../currentUrl}}" />
                    </form>
                  {{else}}
                    <span class="badge fs-6 px-3 py-2
                      {{#if (eq status "pending")}}bg-warning{{/if}}
                      {{#if (eq status "approved")}}bg-success{{/if}}
                      {{#if (eq status "rejected")}}bg-danger{{/if}}
                    ">
                      {{capitalize status}}
                    </span>
                    {{#if (eq status "pending")}}
                      <div class="mt-1"><small class="text-muted">Awaiting review</small></div>
                    {{/if}}
                  {{/if}}
                </td>
              </tr>
            {{else}}
              <tr>
                <td colspan="6" class="text-center py-5">
                  <div class="text-muted">
                    Empty Inbox
                    <h5>No requests match your filters</h5>
                    <p class="mb-3">Try adjusting your search criteria above.</p>
                    <a href="/pick" class="btn btn-primary">Show All Requests</a>
                  </div>
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>

      <!-- PAGINATION -->
      {{#if showPagination}}
      <nav aria-label="Requests pagination" class="mt-4">
        <ul class="pagination justify-content-center">
          {{#if hasPrevPage}}
            <li class="page-item">
              <a class="page-link" href="/pick?page={{prevPage}}&search={{searchQuery}}&status={{statusFilter}}&type={{typeFilter}}" aria-label="Previous">
                Previous
              </a>
            </li>
          {{else}}
            <li class="page-item disabled"><span class="page-link">Previous</span></li>
          {{/if}}

          {{#each pages}}
            <li class="page-item {{#if active}}active{{/if}}">
              <a class="page-link" href="/pick?page={{number}}&search={{../searchQuery}}&status={{../statusFilter}}&type={{../typeFilter}}">{{number}}</a>
            </li>
          {{/each}}

          {{#if hasNextPage}}
            <li class="page-item">
              <a class="page-link" href="/pick?page={{nextPage}}&search={{searchQuery}}&status={{statusFilter}}&type={{typeFilter}}" aria-label="Next">
                Next
              </a>
            </li>
          {{else}}
            <li class="page-item disabled"><span class="page-link">Next</span></li>
          {{/if}}
        </ul>
      </nav>
      {{/if}}
    </div>
  </div>
</div>