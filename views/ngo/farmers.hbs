<div class="container mt-5">
  <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
    <!-- Header with gradient -->
    <div
      class="card-header text-white d-flex justify-content-between align-items-center py-4 px-4"
      style="background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);"
    >
      <div>
        <h3 class="mb-1 fw-bold">
          <i class="bi bi-people-fill me-2"></i>Registered Farmers
        </h3>
        <p class="mb-0 opacity-75 small">Manage and view all registered farmers</p>
      </div>
      <a
        href="/dashboard/ngo"
        class="btn btn-light btn-sm rounded-pill px-4 shadow-sm"
      >
        <i class="bi bi-arrow-left me-1"></i>
        Back to Dashboard
      </a>
    </div>

    <div class="card-body p-4" style="background: #f8f9fa;">
      {{#if farmers.length}}
        <!-- Stats Cards -->
        <div class="row mb-4">
          <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-3 bg-white">
              <div class="card-body d-flex align-items-center">
                <div
                  class="flex-shrink-0 bg-success bg-opacity-10 rounded-circle p-3 me-3"
                >
                  <i class="bi bi-person-check-fill text-success fs-4"></i>
                </div>
                <div>
                  <p class="mb-0 text-muted small">Total Farmers</p>
                  <h4
                    class="mb-0 fw-bold"
                    id="totalCount"
                  >{{farmers.length}}</h4>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Advanced Filters & Search Section -->
        <div class="card border-0 shadow-sm rounded-3 mb-4">
          <div class="card-body p-4">
            <div class="row g-3">
              <!-- Search Bar -->
              <div class="col-lg-4 col-md-6">
                <label class="form-label small fw-semibold text-muted mb-2">
                  <i class="bi bi-search me-1"></i>Search
                </label>
                <div class="input-group">
                  <span class="input-group-text bg-white border-end-0">
                    <i class="bi bi-search text-success"></i>
                  </span>
                  <input
                    type="text"
                    class="form-control border-start-0 ps-0"
                    placeholder="Search by name or email..."
                    id="searchInput"
                    onkeyup="filterTable()"
                  />
                </div>
              </div>

              <!-- Role Filter -->
              <div class="col-lg-2 col-md-6">
                <label class="form-label small fw-semibold text-muted mb-2">
                  <i class="bi bi-shield-check me-1"></i>Role
                </label>
                <select
                  class="form-select"
                  id="roleFilter"
                  onchange="filterTable()"
                >
                  <option value="">All Roles</option>
                  <option value="farmer">Farmer</option>
                  <option value="admin">Admin</option>
                  <option value="coordinator">Coordinator</option>
                </select>
              </div>

              <!-- Date Range Filter -->
              <div class="col-lg-2 col-md-6">
                <label class="form-label small fw-semibold text-muted mb-2">
                  <i class="bi bi-calendar-range me-1"></i>Date Range
                </label>
                <select
                  class="form-select"
                  id="dateFilter"
                  onchange="filterTable()"
                >
                  <option value="">All Time</option>
                  <option value="today">Today</option>
                  <option value="week">This Week</option>
                  <option value="month">This Month</option>
                  <option value="year">This Year</option>
                </select>
              </div>

              <!-- Sort By -->
              <div class="col-lg-2 col-md-6">
                <label class="form-label small fw-semibold text-muted mb-2">
                  <i class="bi bi-sort-down me-1"></i>Sort By
                </label>
                <select
                  class="form-select"
                  id="sortFilter"
                  onchange="filterTable()"
                >
                  <option value="date-desc">Newest First</option>
                  <option value="date-asc">Oldest First</option>
                  <option value="name-asc">Name (A-Z)</option>
                  <option value="name-desc">Name (Z-A)</option>
                  <option value="email-asc">Email (A-Z)</option>
                </select>
              </div>

              <!-- Action Buttons -->
              <div class="col-lg-2 col-md-12">
                <label class="form-label small fw-semibold text-muted mb-2">
                  <i class="bi bi-gear me-1"></i>Actions
                </label>
                <div class="d-flex gap-2">
                  <button
                    class="btn btn-outline-success flex-fill"
                    onclick="resetFilters()"
                    title="Reset Filters"
                  >
                    <i class="bi bi-arrow-clockwise"></i>
                  </button>
                  <button
                    class="btn btn-success flex-fill"
                    onclick="exportData()"
                    title="Export Data"
                  >
                    <i class="bi bi-download"></i>
                  </button>
                </div>
              </div>
            </div>

            <!-- Active Filters Display -->
            <div id="activeFilters" class="mt-3" style="display: none;">
              <div class="d-flex flex-wrap gap-2 align-items-center">
                <small class="text-muted fw-semibold">Active Filters:</small>
                <span
                  class="badge bg-success-subtle text-success border border-success"
                  id="filterBadges"
                ></span>
              </div>
            </div>
          </div>
        </div>

        <!-- Results Counter -->
        <div class="mb-3 d-flex justify-content-between align-items-center">
          <div>
            <span class="text-muted small">
              Showing
              <strong id="showingCount">{{farmers.length}}</strong>
              of
              <strong>{{farmers.length}}</strong>
              farmers
            </span>
          </div>
          <div class="btn-group btn-group-sm" role="group">
            <button
              type="button"
              class="btn btn-outline-secondary"
              onclick="changeView('grid')"
              title="Grid View"
            >
              <i class="bi bi-grid-3x3-gap-fill"></i>
            </button>
            <button
              type="button"
              class="btn btn-outline-secondary active"
              onclick="changeView('table')"
              title="Table View"
            >
              <i class="bi bi-list-ul"></i>
            </button>
          </div>
        </div>

        <!-- Table Card -->
        <div class="card border-0 shadow-sm rounded-3">
          <div class="card-body p-0">
            <div class="table-responsive">
              <table
                class="table table-hover align-middle mb-0"
                id="farmersTable"
              >
                <thead style="background: #e8f5e9;">
                  <tr>
                    <th
                      class="py-3 ps-4 text-muted fw-semibold"
                      style="border-bottom: 2px solid #27ae60;"
                    >
                      <input
                        type="checkbox"
                        class="form-check-input"
                        id="selectAll"
                        onclick="toggleSelectAll()"
                      />
                    </th>
                    <th
                      class="py-3 text-muted fw-semibold"
                      style="border-bottom: 2px solid #27ae60; cursor: pointer;"
                      onclick="sortTable('index')"
                    >
                      #
                      <i class="bi bi-arrow-down-up small"></i>
                    </th>
                    <th
                      class="py-3 text-muted fw-semibold"
                      style="border-bottom: 2px solid #27ae60; cursor: pointer;"
                      onclick="sortTable('name')"
                    >
                      Name
                      <i class="bi bi-arrow-down-up small"></i>
                    </th>
                    <th
                      class="py-3 text-muted fw-semibold"
                      style="border-bottom: 2px solid #27ae60; cursor: pointer;"
                      onclick="sortTable('email')"
                    >
                      Email
                      <i class="bi bi-arrow-down-up small"></i>
                    </th>
                    <th
                      class="py-3 text-muted fw-semibold"
                      style="border-bottom: 2px solid #27ae60;"
                    >
                      Role
                    </th>
                    <th
                      class="py-3 pe-4 text-muted fw-semibold"
                      style="border-bottom: 2px solid #27ae60; cursor: pointer;"
                      onclick="sortTable('date')"
                    >
                      Date Joined
                      <i class="bi bi-arrow-down-up small"></i>
                    </th>
                  </tr>
                </thead>
                <tbody>
                  {{#each farmers}}
                    <tr
                      class="border-bottom farmer-row"
                      data-name="{{this.name}}"
                      data-email="{{this.email}}"
                      data-role="{{this.role}}"
                      data-date="{{this.createdAt}}"
                    >
                      <td class="ps-4">
                        <input
                          type="checkbox"
                          class="form-check-input farmer-checkbox"
                        />
                      </td>
                      <td class="ps-4">
                        <span
                          class="badge bg-light text-dark rounded-circle"
                          style="width: 32px; height: 32px; display: inline-flex; align-items: center; justify-content: center; font-weight: 600;"
                        >
                          {{@index}}
                        </span>
                      </td>
                      <td>
                        <div class="d-flex align-items-center">
                          <div
                            class="bg-success bg-opacity-10 rounded-circle me-2"
                            style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;"
                          >
                            <i class="bi bi-person-fill text-success"></i>
                          </div>
                          <span
                            class="fw-semibold text-dark"
                          >{{this.name}}</span>
                        </div>
                      </td>
                      <td>
                        <span class="text-muted">
                          <i class="bi bi-envelope me-1"></i>{{this.email}}
                        </span>
                      </td>
                      <td>
                        <span
                          class="badge rounded-pill px-3 py-2"
                          style="background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%); font-weight: 500;"
                        >
                          <i class="bi bi-shield-check me-1"></i>{{this.role}}
                        </span>
                      </td>
                      <td class="pe-4">
                        <span class="text-muted">
                          <i class="bi bi-calendar-event me-1"></i>{{formatDate
                            this.createdAt
                          }}
                        </span>
                      </td>
                    </tr>
                  {{/each}}
                </tbody>
              </table>
            </div>

            <!-- No Results Message -->
            <div id="noResults" class="text-center py-5" style="display: none;">
              <div class="mb-3">
                <i class="bi bi-search text-muted" style="font-size: 3rem;"></i>
              </div>
              <h5 class="text-dark mb-2">No Results Found</h5>
              <p class="text-muted">Try adjusting your filters or search terms</p>
              <button
                class="btn btn-success btn-sm rounded-pill px-4"
                onclick="resetFilters()"
              >
                <i class="bi bi-arrow-clockwise me-1"></i>Reset Filters
              </button>
            </div>
          </div>
        </div>

        <!-- Bulk Actions Bar (Hidden by default) -->
        <div
          id="bulkActionsBar"
          class="card border-0 shadow-sm rounded-3 mt-3"
          style="display: none;"
        >
          <div class="card-body p-3">
            <div class="d-flex justify-content-between align-items-center">
              <span class="text-muted">
                <strong id="selectedCount">0</strong>
                farmer(s) selected
              </span>
              <div class="btn-group btn-group-sm">
                <button
                  class="btn btn-outline-success"
                  onclick="bulkAction('export')"
                >
                  <i class="bi bi-download me-1"></i>Export Selected
                </button>
                <button
                  class="btn btn-outline-primary"
                  onclick="bulkAction('email')"
                >
                  <i class="bi bi-envelope me-1"></i>Email Selected
                </button>
                <button
                  class="btn btn-outline-danger"
                  onclick="bulkAction('delete')"
                >
                  <i class="bi bi-trash me-1"></i>Delete Selected
                </button>
              </div>
            </div>
          </div>
        </div>

      {{else}}
        <!-- Empty State -->
        <div class="text-center py-5">
          <div class="mb-4">
            <div
              class="bg-success bg-opacity-10 rounded-circle mx-auto"
              style="width: 80px; height: 80px; display: flex; align-items: center; justify-content: center;"
            >
              <i
                class="bi bi-people text-success"
                style="font-size: 2.5rem;"
              ></i>
            </div>
          </div>
          <h5 class="text-dark mb-2">No Farmers Registered Yet</h5>
          <p class="text-muted">When farmers register, they will appear here.</p>
        </div>
      {{/if}}
    </div>
  </div>
</div>